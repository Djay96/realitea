# --- DeepSeek (AI summarization) ---
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Model slug. Override to your "v4 fast" model if the slug differs.
DEEPSEEK_MODEL=deepseek-chat
# Base URL (OpenAI-compatible). Usually no need to change.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- News API (broader coverage alongside RSS) ---
# Free key from https://newsapi.org (or set NEWS_API_PROVIDER=gnews for https://gnews.io)
NEWS_API_KEY=your-news-api-key
# "newsapi" (default) or "gnews"
NEWS_API_PROVIDER=newsapi

# --- OMDb (IMDb-derived) ---
# Used for (1) show poster fallback when RSS/OG images are missing, and
# (2) the weekly IMDb refresh of the shows catalog (npm run refresh:shows +
#     the Mondays refresh-shows scheduled function). IMDb is the golden source.
# Free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your-omdb-api-key

# --- Manual refresh trigger protection ---
# Any random string. Call POST /api/refresh with header "x-refresh-token: <this>".
REFRESH_TOKEN=change-me-to-a-random-string

# --- Google AdSense ---
# Your AdSense publisher id, e.g. ca-pub-1234567890123456 (leave blank to hide ads)
NEXT_PUBLIC_ADSENSE_CLIENT=
# Ad slot id for the in-feed ad unit
NEXT_PUBLIC_ADSENSE_SLOT=
# In-feed layout key from AdSense embed snippet (data-ad-layout-key)
NEXT_PUBLIC_ADSENSE_LAYOUT_KEY=
